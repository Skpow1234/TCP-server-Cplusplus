{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TCP_SERVER_BUILD_TESTS": "ON",
        "TCP_SERVER_BUILD_BENCHMARKS": "ON"
      }
    },
    {
      "name": "mingw-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "mingw-debug",
      "displayName": "MinGW Debug",
      "inherits": "mingw-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "mingw-release",
      "displayName": "MinGW Release",
      "inherits": "mingw-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "asan-ubsan",
      "displayName": "ASan + UBSan (RelWithDebInfo)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },
    {
      "name": "mingw-asan-ubsan",
      "displayName": "MinGW ASan + UBSan (RelWithDebInfo)",
      "inherits": "mingw-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },
    {
      "name": "tsan",
      "displayName": "TSan (RelWithDebInfo)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_CXX_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread"
      }
    },
    {
      "name": "mingw-tsan",
      "displayName": "MinGW TSan (RelWithDebInfo)",
      "inherits": "mingw-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_CXX_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread"
      }
    },
    {
      "name": "clang-tidy-ci",
      "displayName": "Clang Debug (clang-tidy / CI parity)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "fuzz-standalone",
      "displayName": "MinGW Debug + decoder fuzz harness (file/stdin replay)",
      "inherits": "mingw-debug",
      "cacheVariables": {
        "TCP_SERVER_BUILD_FUZZ": "ON"
      }
    },
    {
      "name": "fuzz-libfuzzer",
      "displayName": "Clang Debug + libFuzzer decoder harness",
      "inherits": "clang-tidy-ci",
      "cacheVariables": {
        "TCP_SERVER_BUILD_FUZZ": "ON",
        "TCP_SERVER_FUZZ_LIBFUZZER": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "mingw-release",
      "configurePreset": "mingw-release"
    },
    {
      "name": "asan-ubsan",
      "configurePreset": "asan-ubsan"
    },
    {
      "name": "mingw-asan-ubsan",
      "configurePreset": "mingw-asan-ubsan"
    },
    {
      "name": "tsan",
      "configurePreset": "tsan"
    },
    {
      "name": "mingw-tsan",
      "configurePreset": "mingw-tsan"
    },
    {
      "name": "clang-tidy-ci",
      "configurePreset": "clang-tidy-ci"
    },
    {
      "name": "fuzz-standalone",
      "configurePreset": "fuzz-standalone"
    },
    {
      "name": "fuzz-libfuzzer",
      "configurePreset": "fuzz-libfuzzer"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "execution": {
        "stopOnFailure": true
      }
    },
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug",
      "execution": {
        "stopOnFailure": true
      }
    },
    {
      "name": "asan-ubsan",
      "configurePreset": "asan-ubsan",
      "execution": {
        "stopOnFailure": true
      }
    },
    {
      "name": "mingw-asan-ubsan",
      "configurePreset": "mingw-asan-ubsan",
      "execution": {
        "stopOnFailure": true
      }
    },
    {
      "name": "tsan",
      "configurePreset": "tsan",
      "execution": {
        "stopOnFailure": true
      }
    },
    {
      "name": "mingw-tsan",
      "configurePreset": "mingw-tsan",
      "execution": {
        "stopOnFailure": true
      }
    }
  ]
}

